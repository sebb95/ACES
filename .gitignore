# ----------------------------
# Project: data & outputs
# ----------------------------

# Real data should never be committed
# Ignore ALL data by default
data/*

# Allow only sample dataset
!data/sample/
!data/sample/**

# Sample dataset used for testing is allowed
# data/sample/ is intentionally tracked

# Keep empty structure where needed
!data/input/
!data/input/.gitkeep
!data/history
!data/history/.gitkeep

# ----------------------------
# Training / experiment outputs
# ----------------------------

# Ultralytics default runs folder if accidentally created
runs/
# Dataset cache files
*.cache

# ----------------------------
# Outputs (keep structure only)
# ----------------------------

outputs/**
!outputs/
!outputs/.gitkeep

!outputs/runs/
outputs/runs/**
!outputs/runs/.gitkeep

!outputs/weights/
outputs/weights/**
!outputs/weights/.gitkeep

# Logs
logs/
*.log

